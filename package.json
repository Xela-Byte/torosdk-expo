{
  "name": "torosdk-expo",
  "version": "0.1.7",
  "description": "Expo wrapper for torosdk — secure password storage, TanStack Query hooks, and CLI init",
  "main": "dist/react/index.js",
  "types": "dist/react/index.d.ts",
  "bin": {
    "torosdk-expo": "./dist/cli/init.js"
  },
  "exports": {
    ".": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./cli": "./dist/cli/init.js"
  },
  "files": [
    "dist/",
    "ios/",
    "torosdk-expo.podspec",
    "README.md",
    "LICENSE"
  ],
  "react-native": {
    "sourceDir": "./ios"
  },
  "scripts": {
    "build": "tsc && cp -r src/cli/templates dist/cli/",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:integration": "RUN_INTEGRATION=1 jest --testPathPattern='integration/' --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "keywords": [
    "toronet",
    "torosdk",
    "expo",
    "react-native",
    "blockchain",
    "wallet"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "expo-local-authentication": ">=14.0.0",
    "expo-secure-store": ">=12.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.73.0"
  },
  "peerDependenciesMeta": {
    "expo-local-authentication": {
      "optional": true
    }
  },
  "dependencies": {
    "axios": ">=1.7.0",
    "torosdk": "^0.2.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "expo-local-authentication": "^56.0.4",
    "expo-secure-store": "^56.0.4",
    "jest": "^29.7.0",
    "react": "^19.0.0",
    "react-test-renderer": "^19.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.60.1"
  }
}
